{
  "name": "essk",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm dev:up",
    "dev:up": "docker compose -f infra/compose/docker-compose.yml up --build",
    "dev:backend": "docker compose -f infra/compose/docker-compose.yml up -d --build postgres redis migrate migrate-shared seed backend",
    "dev:web": "NEXT_PUBLIC_API_BASE_URL=http://localhost:18080/api/v1 pnpm --filter @essk/web dev",
    "dev:edge": "docker compose -f infra/compose/docker-compose.yml --profile edge up --build",
    "dev:down": "docker compose -f infra/compose/docker-compose.yml down",
    "dev:logs": "docker compose -f infra/compose/docker-compose.yml logs -f",
    "dev:reset": "docker compose -f infra/compose/docker-compose.yml down -v",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "codegen": "pnpm --filter @essk/sdk-ts codegen",
    "policy:check": "go -C services/backend run ./cmd/essk policy check --all"
  }
}
