ESSK_APP_ENV=local
ESSK_APP_NAME=ESSK Backend
ESSK_APP_VERSION=0.1.0
ESSK_BACKEND_PORT=8080
ESSK_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ESSK_LOG_LEVEL=info
ESSK_LOG_PRETTY=true

DATABASE_URL=postgres://essk:essk@localhost:5432/essk?sslmode=disable

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ISSUER=essk
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
JWT_SIGNING_KEY=change-me-local-only
